[Unit]
Description=PPanel Node (ppnode, source-in-source-out enabled)
Documentation=https://github.com/echoowall/ppanel-node
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ppnode server --config /etc/PPanel-node/config.yml
Restart=on-failure
RestartSec=5s
# 高并发节点放开文件描述符上限
LimitNOFILE=1048576
# 绑定本机已有 IP 作为出站源无需特权；如需绑定 <1024 端口再打开下一行
# AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
